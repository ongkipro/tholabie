---
export interface Props {
  icon: any;
  title: string;
  desc: string;
  delay?: string;
  class?: string;
}

const { icon: Icon, title, desc, delay = '', class: extraClass = '' } = Astro.props;
---

<div class={`animate-on-scroll ${delay} bg-white/10 backdrop-blur-sm border border-white/20 p-6 rounded-2xl text-white hover:bg-white/20 transition-colors ${extraClass}`}>
  <Icon class="w-8 h-8 text-accent mb-4" />
  <h3 class="text-lg font-bold mb-2">{title}</h3>
  <p class="text-sm text-gray-300">{desc}</p>
</div>
