---
import { Quote, Star, Building } from '@lucide/astro';

const testimonials = [
  {
    text: 'Sistem asrama yang sangat tertib. Saya melihat perubahan drastis pada kemandirian dan kedisiplinan ibadah anak saya sejak bergabung dengan program ini.',
    author: 'Bpk. Wahyudi',
    role: 'Wali Santri',
    initial: 'W',
  },
  {
    text: 'Dulu saya bingung mau kuliah tapi terbentur biaya. Di sini, saya difasilitasi penuh, bahkan diajari jualan online dan ilmu digital marketing. Alhamdulillah.',
    author: 'Ahmad F.',
    role: 'Calon Alumni D3 TI',
    initial: 'A',
  },
  {
    text: 'Lingkungannya sangat mendukung untuk berkembang. Pagi mengaji, siang kuliah formal, sore belajar AI. Kurikulumnya benar-benar menyiapkan mental kerja.',
    author: 'Iqbal M.',
    role: 'Santri Aktif',
    initial: 'I',
  },
];
---
<section id="testimoni" class="py-20 bg-surface border-y border-gray-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-12 items-center mb-24">
      <div class="animate-on-scroll">
        <h2 class="text-2xl font-serif font-bold text-secondary mb-6">"Visi untuk masa depan pendidikan Islam di Indonesia."</h2>
        <p class="text-gray-600 italic mb-6">
          "THOLABIE mewakili evolusi yang sangat dibutuhkan. Kita tidak bisa hanya membekali pemuda kita dengan teori agama; kita harus memberdayakan mereka dengan alat praktis untuk bernavigasi dan memimpin dalam ekonomi modern, sambil tetap mempertahankan identitas keislaman mereka secara kokoh."
        </p>
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 bg-gray-200 rounded-full overflow-hidden border-2 border-primary/20 shadow-sm flex items-center justify-center font-bold text-primary font-serif text-xl bg-white">
            TP
          </div>
          <div>
            <p class="font-bold text-secondary text-sm">Dewan Pembina Institusi</p>
            <p class="text-xs text-gray-500">Pondok Pesantren THOLABIE CIBS</p>
          </div>
        </div>
      </div>
      
      <div class="animate-on-scroll delay-200 bg-white p-8 rounded-3xl border border-gray-100 shadow-sm text-center">
        <p class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-6">Mitra Pendidikan Formal</p>
        <div class="flex justify-center items-center gap-6 opacity-70 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-500">
          <div class="h-16 px-6 bg-gray-50 rounded-xl flex items-center justify-center text-gray-600 font-serif font-bold border border-gray-200 shadow-sm">
            <Building class="w-6 h-6 mr-3 text-primary" /> POLITEKNIK KOTA MALANG
          </div>
        </div>
      </div>
    </div>

    <div class="text-center mb-12 animate-on-scroll">
      <h3 class="text-2xl font-serif font-bold text-secondary">Apa Kata Mereka?</h3>
    </div>
    
    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map((test) => (
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 relative animate-on-scroll">
          <Quote class="absolute top-6 right-6 w-8 h-8 text-primary/10" />
          <div class="flex items-center gap-1 mb-4 text-accent">
            <Star class="w-4 h-4 fill-current" />
            <Star class="w-4 h-4 fill-current" />
            <Star class="w-4 h-4 fill-current" />
            <Star class="w-4 h-4 fill-current" />
            <Star class="w-4 h-4 fill-current" />
          </div>
          <p class="text-gray-600 text-sm mb-6 leading-relaxed">"{test.text}"</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold">
              {test.initial}
            </div>
            <div>
              <p class="text-sm font-bold text-secondary">{test.author}</p>
              <p class="text-xs text-gray-500">{test.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
