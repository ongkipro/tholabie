---
export interface Props {
  icon: any;
  title: string;
  desc: string;
  iconBg?: string;
  iconColor?: string;
  delay?: string;
}

const { icon: Icon, title, desc, iconBg = 'bg-green-50', iconColor = 'text-green-600', delay = '' } = Astro.props;
---

<div class={`animate-on-scroll ${delay} bg-white p-6 rounded-2xl shadow-sm border border-gray-100 text-center hover:shadow-md transition-shadow`}>
  <div class={`w-12 h-12 mx-auto ${iconBg} rounded-full flex items-center justify-center ${iconColor} mb-3`}>
    <Icon class="w-6 h-6" />
  </div>
  <h4 class="font-bold text-sm text-secondary mb-2">{title}</h4>
  <p class="text-xs text-gray-500">{desc}</p>
</div>
