---
import { ChevronRight, MapPin, Phone } from '@lucide/astro';
import Ornament from './Ornament.astro';
---
<footer class="bg-secondary text-gray-400 py-16 border-t-2 border-accent relative overflow-hidden">
  <!-- Subtle Islamic pattern overlay on dark Kiswah background -->
  <div class="absolute inset-0 bg-islamic-pattern opacity-5 -z-10"></div>
  
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid md:grid-cols-4 gap-8 mb-12">
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-4 group">
          <img loading="lazy" decoding="async"
            src="/img/logo.webp"
            alt="Logo Pondok Pesantren THOLABIE CIBS"
            class="w-9 h-9 object-contain rounded-full shadow-md border border-accent/30 group-hover:opacity-80 transition-opacity"
          />
          <span class="font-serif font-bold text-white tracking-wider">THOLABIE</span>
        </a>
        <p class="text-sm leading-relaxed max-w-sm mb-4 text-gray-300">
          Pondok Pesantren THOLABIE Classic International Boarding School. Mengintegrasikan pembentukan karakter Islami (Akhlaq) yang mendalam dengan pendidikan tinggi formal dan keterampilan digital masa depan.
        </p>
      </div>
      
      <div>
        <h4 class="text-accent font-bold mb-4 font-serif">Tautan Cepat</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/tentang" class="hover:text-accent transition-colors flex items-center gap-2"><ChevronRight class="w-3 h-3 text-accent" /> Tentang Kami</a></li>
          <li><a href="/beasiswa" class="hover:text-accent transition-colors flex items-center gap-2"><ChevronRight class="w-3 h-3 text-accent" /> Beasiswa 2026</a></li>
          <li><a href="/asrama" class="hover:text-accent transition-colors flex items-center gap-2"><ChevronRight class="w-3 h-3 text-accent" /> Kehidupan Asrama</a></li>
          <li><a href="/kontak" class="hover:text-accent transition-colors flex items-center gap-2"><ChevronRight class="w-3 h-3 text-accent" /> Tanya Jawab & FAQ</a></li>
        </ul>
      </div>
      
      <div>
        <h4 class="text-accent font-bold mb-4 font-serif">Kontak Kami</h4>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-3">
            <MapPin class="w-5 h-5 mt-0.5 shrink-0 text-accent" />
            <span class="leading-relaxed text-gray-300">
              <strong>Pondok Pesantren THOLABIE CIBS</strong><br/>
              Jalan Kyai Malik Dalam Jl. Dukuh Baran, RT.01/RW.07, Buring, Kedungkandang, Malang 65136
            </span>
          </li>
          <li class="flex items-center gap-3">
            <Phone class="w-5 h-5 shrink-0 text-accent" />
            <a href="https://wa.me/6285183003060" class="hover:text-accent transition-colors font-semibold text-gray-300">+62 851 8300 3060</a>
          </li>
        </ul>
      </div>
    </div>
    
    <div class="pt-8 border-t border-accent/25 text-sm flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex flex-col md:flex-row items-center gap-2 md:gap-6 text-center md:text-left">
        <p class="text-gray-400">&copy; 2026 Pondok Pesantren THOLABIE. Hak Cipta Dilindungi.</p>
        <div class="text-gray-500 flex items-center gap-2">
          Crafted by 
          <a href="https://ongki.pro" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-1.5 text-gray-300 hover:text-accent transition-all duration-300 font-medium">
            <svg class="w-4 h-4 text-accent animate-[spin_5s_linear_infinite]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"></polygon>
              <line x1="12" y1="22" x2="12" y2="15.5"></line>
              <polyline points="22 8.5 12 15.5 2 8.5"></polyline>
              <polyline points="2 15.5 12 8.5 22 15.5"></polyline>
              <line x1="12" y1="2" x2="12" y2="8.5"></line>
            </svg>
            ongki.pro
          </a>
        </div>
      </div>
      <div class="font-arabic text-xl text-accent/60 mt-2 md:mt-0" dir="rtl">وَاللَّهُ الْمُسْتَعَانُ</div>
    </div>
  </div>
</footer>
