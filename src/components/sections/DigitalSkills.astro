---
import { Users, Code, CheckCircle, ArrowRight } from '@lucide/astro';
import Ornament from '../Ornament.astro';
---
<section id="keahlian" class="py-16 md:py-24 bg-secondary text-white relative overflow-hidden">
  <div class="absolute inset-0 bg-islamic-pattern opacity-10"></div>
  
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-5 gap-12 items-center">
      <div class="lg:col-span-2 animate-on-scroll">
        <span class="text-accent uppercase tracking-widest text-xs font-bold mb-4 block">Lebih Dari Sekadar Akademik</span>
        <h2 class="text-3xl md:text-4xl font-serif font-bold mb-6">Membekali Untuk Ekonomi Digital</h2>
        <p class="text-gray-400 leading-relaxed mb-8">
          Kami tidak hanya ingin santri kami lulus; kami ingin mereka berjaya. Program inkubasi intensif kami memastikan setiap lulusan memiliki keterampilan praktis yang sangat dicari di pasar modern.
        </p>
        <a href="/kurikulum" class="inline-flex items-center text-accent font-semibold hover:text-white transition-colors group">
          Pelajari kurikulum digital selengkapnya <ArrowRight class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" />
        </a>
      </div>
      
      <div class="lg:col-span-3 grid sm:grid-cols-2 gap-6">
        <!-- Life Skills -->
        <div class="animate-on-scroll delay-100 bg-white/5 border border-accent/20 p-8 rounded-2xl hover:bg-white/10 transition-all duration-300 shadow-lg">
          <div class="w-12 h-12 rounded-lg bg-white/10 flex items-center justify-center mb-6 border border-accent/30">
            <Users class="w-6 h-6 text-accent" />
          </div>
          <h3 class="text-xl font-bold mb-4 text-white">Kecakapan Hidup (Life Skills)</h3>
          <ul class="space-y-3 text-sm text-gray-300">
            <li class="flex items-center gap-2"><CheckCircle class="w-4 h-4 text-accent" /> Public Speaking & Komunikasi</li>
            <li class="flex items-center gap-2"><CheckCircle class="w-4 h-4 text-accent" /> Manajemen & Kepemimpinan</li>
            <li class="flex items-center gap-2"><CheckCircle class="w-4 h-4 text-accent" /> Manajemen Waktu</li>
            <li class="flex items-center gap-2"><CheckCircle class="w-4 h-4 text-accent" /> Pola Pikir Kewirausahaan</li>
          </ul>
        </div>
        <!-- Digital Skills -->
        <div class="animate-on-scroll delay-200 bg-white/5 border border-accent/20 p-8 rounded-2xl hover:bg-white/10 transition-all duration-300 shadow-lg">
          <div class="w-12 h-12 rounded-lg bg-white/10 flex items-center justify-center mb-6 border border-accent/30">
            <Code class="w-6 h-6 text-accent-light" />
          </div>
          <h3 class="text-xl font-bold mb-4 text-white">Keahlian Digital</h3>
          <ul class="space-y-3 text-sm text-gray-300">
            <li class="flex items-center gap-2"><CheckCircle class="w-4 h-4 text-accent" /> Digital Marketing</li>
            <li class="flex items-center gap-2"><CheckCircle class="w-4 h-4 text-accent" /> Content Creation & Desain</li>
            <li class="flex items-center gap-2"><CheckCircle class="w-4 h-4 text-accent" /> Pemasaran Toko Online</li>
            <li class="flex items-center gap-2"><CheckCircle class="w-4 h-4 text-accent" /> AI untuk Produktivitas</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
