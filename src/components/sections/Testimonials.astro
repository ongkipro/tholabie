---
import { Quote, Star, Building } from '@lucide/astro';
import Ornament from '../Ornament.astro';

const testimonials = [
  {
    text: 'Sistem asrama yang sangat tertib. Saya melihat perubahan drastis pada kemandirian dan kedisiplinan ibadah anak saya sejak bergabung dengan program ini.',
    author: 'Bpk. Wahyudi',
    role: 'Wali Santri (Malang)',
    image: '/img/testimonial_wahyudi.jpg',
  },
  {
    text: 'Dulu saya bingung mau kuliah tapi terbentur biaya. Di sini, saya difasilitasi penuh, bahkan diajari jualan online dan ilmu digital marketing. Alhamdulillah.',
    author: 'Ahmad F.',
    role: 'Alumni D3 Teknik Informatika',
    image: '/img/testimonial_ahmad.jpg',
  },
  {
    text: 'Lingkungannya sangat mendukung untuk berkembang. Pagi mengaji, siang kuliah formal, sore belajar AI. Kurikulumnya benar-benar menyiapkan mental kerja.',
    author: 'Iqbal M.',
    role: 'Santri Aktif (D3 TI)',
    image: '/img/testimonial_iqbal.jpg',
  },
  {
    text: 'Sebagai ibu, saya merasa sangat tenang menyekolahkan anak di sini. Lingkungan pergaulannya terjaga dari pengaruh negatif luar dan akhlaknya terus dibimbing.',
    author: 'Ibu Siti Aminah',
    role: 'Wali Santri (Sidoarjo)',
    image: '/img/testimonial_siti.jpg',
  },
  {
    text: 'Dosen di kampus mengapresiasi karena santri Tholabie selalu memiliki kedisiplinan dan keterampilan di atas rata-rata mahasiswa lainnya karena bekal program inkubasi.',
    author: 'Rahmat H.',
    role: 'Santri Aktif (D3 Telekomunikasi)',
    image: '/img/testimonial_rahmat.jpg',
  },
  {
    text: 'Kombinasi beasiswa kuliah gratis dan pelatihan AI/digital adalah impian. Saya kini siap bersaing di industri kreatif setelah dibimbing secara intensif.',
    author: 'Fathur R.',
    role: 'Santri Aktif (D3 Mekatronika)',
    image: '/img/testimonial_fathur.jpg',
  },
];
---
<section id="testimoni" class="py-16 md:py-24 bg-surface border-y border-accent/20 relative overflow-hidden">
  <div class="absolute inset-0 bg-islamic-pattern opacity-30 -z-10"></div>
  
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid md:grid-cols-2 gap-12 items-center mb-24">
      <div class="animate-on-scroll">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-secondary mb-6 leading-tight">"Visi untuk masa depan pendidikan Islam di Indonesia."</h2>
        <p class="text-gray-600 italic mb-6 leading-relaxed">
          "THOLABIE mewakili evolusi yang sangat dibutuhkan. Kita tidak bisa hanya membekali pemuda kita dengan teori agama; kita harus memberdayakan mereka dengan alat praktis untuk bernavigasi dan memimpin dalam ekonomi modern, sambil tetap mempertahankan identitas keislaman mereka secara kokoh."
        </p>
        <div class="flex items-center gap-4">
          <img 
            src="/img/pembina_portrait.jpg" 
            alt="Dewan Pembina Pesantren THOLABIE CIBS" 
            class="w-16 h-16 rounded-full object-cover border-2 border-accent shadow-premium"
          />
          <div>
            <p class="font-bold text-secondary text-sm">Dewan Pembina Institusi</p>
            <p class="text-xs text-gray-500">Pondok Pesantren THOLABIE CIBS</p>
          </div>
        </div>
      </div>
      
      <div class="animate-on-scroll delay-200 bg-white p-8 rounded-3xl border border-accent/20 shadow-premium text-center relative overflow-hidden">
        <div class="absolute inset-0 bg-islamic-pattern opacity-10 -z-10"></div>
        <p class="text-xs font-bold text-accent-dark uppercase tracking-widest mb-6">Mitra Pendidikan Formal</p>
        <div class="flex justify-center items-center gap-6">
          <div class="h-16 px-6 bg-surface-alt rounded-xl flex items-center justify-center text-primary-dark font-serif font-bold border border-accent/20 shadow-sm">
            <Building class="w-6 h-6 mr-3 text-accent" /> POLITEKNIK KOTA MALANG
          </div>
        </div>
      </div>
    </div>

    <div class="text-center mb-12 animate-on-scroll">
      <h3 class="text-3xl md:text-4xl font-serif font-bold text-secondary">Apa Kata Mereka?</h3>
      <Ornament type="divider" class="mb-4" />
    </div>
    
    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map((test) => (
        <div class="bg-white p-8 rounded-2xl shadow-premium border border-accent/15 hover:border-accent/30 hover:-translate-y-1 transition-all duration-300 relative animate-on-scroll group">
          <Quote class="absolute top-6 right-6 w-8 h-8 text-accent/10" />
          <div class="flex items-center gap-1 mb-4 text-accent">
            <Star class="w-4 h-4 fill-current" />
            <Star class="w-4 h-4 fill-current" />
            <Star class="w-4 h-4 fill-current" />
            <Star class="w-4 h-4 fill-current" />
            <Star class="w-4 h-4 fill-current" />
          </div>
          <p class="text-gray-600 text-sm mb-6 leading-relaxed">"{test.text}"</p>
          <div class="flex items-center gap-3">
            <img 
              src={test.image} 
              alt={test.author} 
              class="w-10 h-10 rounded-full object-cover border border-accent/25 group-hover:scale-105 transition-transform"
            />
            <div>
              <p class="text-sm font-bold text-secondary">{test.author}</p>
              <p class="text-xs text-gray-500">{test.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
