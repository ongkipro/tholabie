---
import { ArrowRight } from '@lucide/astro';
import Ornament from '../Ornament.astro';

const steps = [
  {
    num: '1',
    title: 'Registrasi',
    desc: 'Hubungi admin via WhatsApp untuk menyatakan minat.',
  },
  {
    num: '2',
    title: 'Seleksi Berkas',
    desc: 'Penyerahan dokumen akademik & keterangan tidak mampu.',
  },
  {
    num: '3',
    title: 'Wawancara',
    desc: 'Penilaian komitmen, adab, dan kesiapan mental belajar.',
  },
  {
    num: '4',
    title: 'Penerimaan Final',
    desc: 'Pengumuman resmi dan registrasi masuk ke CIBS & Politeknik.',
  },
];
---
<section class="py-16 md:py-24 bg-surface relative overflow-hidden">
  <div class="absolute inset-0 bg-islamic-pattern opacity-30 -z-10"></div>
  
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16 animate-on-scroll">
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-secondary text-center">Proses Pendaftaran yang Mudah</h2>
      <Ornament type="divider" class="mb-6" />
    </div>
    
    <div class="relative">
      <div class="hidden md:block absolute top-1/2 left-0 w-full h-0.5 bg-gradient-to-r from-primary/30 via-accent/50 to-primary/30 -translate-y-1/2"></div>
      
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative z-10">
        {steps.map((step) => (
          <div class="animate-on-scroll bg-white p-6 rounded-2xl border border-accent/15 relative text-center shadow-premium hover:border-accent/35 transition-all duration-300">
            <div class="w-10 h-10 rounded-full bg-primary text-white font-bold flex items-center justify-center absolute -top-5 left-1/2 -translate-x-1/2 border-2 border-accent shadow-md">
              {step.num}
            </div>
            <h4 class="font-bold text-secondary mt-5 mb-2">{step.title}</h4>
            <p class="text-sm text-gray-500 leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
