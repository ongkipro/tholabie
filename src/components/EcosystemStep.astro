---
export interface Props {
  icon: any;
  title: string;
  desc: string;
  delay?: string;
  bgColor?: string;
  textColor?: string;
  isDark?: boolean;
}

const { icon: Icon, title, desc, delay = '', bgColor = 'bg-primary', textColor = 'text-white', isDark = false } = Astro.props;
---

<div class={`animate-on-scroll ${delay} ${isDark ? 'bg-primary-dark border-primary shadow-premium' : 'bg-white border-gray-100 shadow-sm'} w-full md:w-1/5 p-6 rounded-2xl border flex flex-col items-center relative group hover:shadow-md transition-shadow`}>
  <div class={`w-16 h-16 rounded-full ${isDark ? 'bg-white text-primary-dark' : `${bgColor} ${textColor}`} flex items-center justify-center mb-4 group-hover:scale-110 transition-transform shadow-lg relative`}>
    <Icon class="w-7 h-7" />
  </div>
  <h3 class={`font-bold ${isDark ? 'text-white' : 'text-secondary'} text-sm mb-2 text-center`}>{title}</h3>
  <p class={`text-xs ${isDark ? 'text-gray-300' : 'text-gray-500'} text-center`}>{desc}</p>
</div>
