---
import { Info, Award, Home, Laptop, MessageSquare, HelpCircle, MessageCircle, ChevronRight } from '@lucide/astro';

const navLinks = [
  { name: 'Tentang Kami', href: '/tentang', id: 'tentang', icon: Info },
  { name: 'Program Beasiswa', href: '/beasiswa', id: 'beasiswa', icon: Award },
  { name: 'Kehidupan Asrama', href: '/asrama', id: 'asrama', icon: Home },
  { name: 'Keahlian Digital', href: '/kurikulum', id: 'kurikulum', icon: Laptop },
  { name: 'Hubungi Kami', href: '/kontak', id: 'kontak', icon: HelpCircle },
];
---
<header
  id="navbar"
  class="fixed w-full top-0 z-50 transition-all duration-300 glass-nav py-4"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center">
      <a href="/" aria-label="Beranda Pondok Pesantren THOLABIE CIBS" class="flex items-center gap-2 group">
        <img
          src="/img/logo.webp"
          alt="Logo Pondok Pesantren THOLABIE CIBS"
          class="w-10 h-10 object-contain rounded-full shadow-md border border-accent/40 group-hover:opacity-80 transition-all duration-300"
        />
        <div class="flex flex-col">
          <span class="font-serif font-bold text-lg leading-none text-primary group-hover:text-accent transition-colors">THOLABIE</span>
          <span class="text-xs tracking-widest text-secondary uppercase font-semibold mt-1">CIBS</span>
        </div>
      </a>

      <nav class="hidden md:flex space-x-8 items-center">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="nav-link text-sm font-medium text-secondary hover:text-accent transition-colors"
            data-link={link.id}
          >
            {link.name}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-4">
        <a
          href="https://wa.me/6285183003060"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden md:inline-flex items-center justify-center px-6 py-2.5 text-sm font-bold rounded-full text-primary-dark bg-accent hover:bg-accent-light border border-accent/30 shadow-sm hover:shadow-premium-hover active:scale-95 transition-all duration-300"
        >
          Daftar Sekarang
        </a>
        <button
          id="mobile-menu-btn"
          aria-label="Toggle Menu"
          class="md:hidden flex items-center justify-center w-10 h-10 rounded-full border border-primary/10 bg-primary/5 hover:bg-primary/10 text-secondary focus:outline-none transition-all duration-300 active:scale-90"
        >
          <div class="flex flex-col justify-between w-5 h-3.5 relative">
            <span class="w-full h-[2px] bg-current rounded-full transition-all duration-300 origin-left"></span>
            <span class="w-full h-[2px] bg-current rounded-full transition-all duration-300"></span>
            <span class="w-full h-[2px] bg-current rounded-full transition-all duration-300 origin-left"></span>
          </div>
        </button>
      </div>
    </div>
  </div>

  <!-- Floating Mobile Menu Drawer -->
  <div
    id="mobile-menu"
    class="md:hidden absolute top-[76px] left-4 right-4 w-[calc(100%-32px)] bg-white/95 backdrop-blur-lg border border-accent/25 shadow-2xl rounded-2xl overflow-hidden"
  >
    <div class="absolute inset-0 bg-islamic-pattern opacity-5 -z-10"></div>
    <div class="p-3 space-y-1.5 relative z-10">
      {navLinks.map((link) => {
        const Icon = link.icon;
        return (
          <a
            href={link.href}
            class="mobile-nav-link flex items-center justify-between p-2.5 text-sm font-bold text-secondary hover:bg-primary/5 rounded-xl border border-transparent hover:border-accent/15 transition-all duration-300 group"
          >
            <div class="flex items-center gap-3">
              <div class="mobile-icon-wrapper w-9 h-9 rounded-xl bg-primary/5 flex items-center justify-center text-primary transition-colors shrink-0">
                <Icon class="w-4.5 h-4.5 text-primary shrink-0" />
              </div>
              <span class="font-serif text-secondary group-hover:text-primary transition-colors">{link.name}</span>
            </div>
            <ChevronRight class="w-4 h-4 text-accent/50 group-hover:text-accent group-hover:translate-x-1 transition-all" />
          </a>
        );
      })}

      <!-- Mobile Menu CTA Button -->
      <div class="pt-3 border-t border-accent/20 mt-3 px-1">
        <a
          href="https://wa.me/6285183003060"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 w-full px-6 py-3 text-sm font-bold rounded-xl text-primary-dark bg-accent hover:bg-accent-light border border-accent/30 shadow-md active:scale-98 transition-all duration-300 group"
        >
          <MessageCircle class="w-4 h-4 shrink-0 text-primary-dark group-hover:scale-110 transition-transform" />
          Daftar via WhatsApp
        </a>
      </div>

      <!-- Quick Info / Subtitle -->
      <div class="mt-4 text-center pb-1">
        <p class="text-[9px] text-gray-400 font-serif font-bold">Pondok Pesantren THOLABIE CIBS</p>
        <p class="text-[8px] text-gray-500 mt-0.5">Malang, Jawa Timur &bull; Hubungi: +62 851 8300 3060</p>
      </div>
    </div>
  </div>
</header>
