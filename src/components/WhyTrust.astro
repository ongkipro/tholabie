---
import { ShieldCheck, Eye, Clock, Map, Briefcase } from '@lucide/astro';

const reasons = [
  {
    icon: ShieldCheck,
    title: 'Lingkungan Islami',
    desc: 'Pergaulan yang terjaga dan fokus pada adab & akhlak.',
    bgColor: 'bg-green-50',
    textColor: 'text-green-600',
  },
  {
    icon: Eye,
    title: 'Perkembangan Terawasi',
    desc: 'Mentoring langsung dari pembimbing akademik & spiritual.',
    bgColor: 'bg-blue-50',
    textColor: 'text-blue-600',
  },
  {
    icon: Clock,
    title: 'Sistem Kedisiplinan',
    desc: 'Tidak ada waktu terbuang; rutinitas harian yang produktif.',
    bgColor: 'bg-yellow-50',
    textColor: 'text-yellow-600',
  },
  {
    icon: Map,
    title: 'Jalur yang Jelas',
    desc: 'Perjalanan terstruktur dari pendaftaran hingga siap karier.',
    bgColor: 'bg-purple-50',
    textColor: 'text-purple-600',
  },
  {
    icon: Briefcase,
    title: 'Persiapan Praktis',
    desc: 'Keterampilan yang langsung menunjang kemandirian finansial.',
    bgColor: 'bg-red-50',
    textColor: 'text-red-600',
  },
];
---
<section class="py-24 bg-surface-alt border-t border-gray-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16 animate-on-scroll">
      <h2 class="text-3xl font-serif font-bold text-secondary mb-4">Mengapa Orang Tua Mempercayai Tholabie</h2>
      <p class="text-gray-600">Ketenangan batin mengetahui putra-putri Anda berada dalam lingkungan yang aman, terstruktur, dan berorientasi masa depan.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4">
      {reasons.map((reason, idx) => {
        const Icon = reason.icon;
        return (
          <div
            class="animate-on-scroll bg-white p-6 rounded-2xl shadow-sm border border-gray-100 text-center hover:shadow-md transition-shadow"
          >
            <div class={`w-12 h-12 mx-auto ${reason.bgColor} rounded-full flex items-center justify-center ${reason.textColor} mb-3`}>
              <Icon class="w-6 h-6" />
            </div>
            <h4 class="font-bold text-sm text-secondary mb-2">{reason.title}</h4>
            <p class="text-xs text-gray-500">{reason.desc}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>
