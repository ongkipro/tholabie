---
export interface Props {
  title?: string;
  description?: string;
}

const title = Astro.props.title || "Pondok Pesantren THOLABIE CIBS | Beasiswa Politeknik Kota Malang";
const description = Astro.props.description || "Pondok Pesantren THOLABIE Classic International Boarding School. Pendidikan asrama Islami terpadu dengan beasiswa D3 Politeknik Kota Malang dan inkubasi keahlian digital. Menjembatani Iman, Ilmu, dan Karier Masa Depan.";

import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#064E3B" />
  
  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />
  <link rel="canonical" href="https://pesantrentholabie.com/" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://pesantrentholabie.com/" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://pesantrentholabie.com/img/pondok-pesantren-tholabie-malang-cibs.webp" />
  <meta property="og:site_name" content="Pondok Pesantren THOLABIE CIBS" />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content="https://pesantrentholabie.com/" />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content="https://pesantrentholabie.com/img/pondok-pesantren-tholabie-malang-cibs.webp" />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "School",
      "name": "Pondok Pesantren THOLABIE CIBS",
      "url": "https://pesantrentholabie.com/",
      "logo": "https://pesantrentholabie.com/img/logo.webp",
      "image": "https://pesantrentholabie.com/img/pondok-pesantren-tholabie-malang-cibs.webp",
      "description": "Pendidikan asrama Islami terpadu dengan beasiswa D3 Politeknik Kota Malang dan inkubasi keahlian digital. Menjembatani Iman, Ilmu, dan Karier Masa Depan.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Jl. KH Malik Dalam RT 01, RW 07, Baran, Buring",
        "addressLocality": "Kedungkandang",
        "addressRegion": "Malang",
        "postalCode": "65137",
        "addressCountry": "ID"
      },
      "telephone": "+6285183003060",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+6285183003060",
        "contactType": "admissions",
        "areaServed": "ID",
        "availableLanguage": "Indonesian"
      }
    }
  </script>

  <!-- Fonts: Preconnect + optimized loading -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link 
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Amiri+Quran&display=swap" 
    rel="stylesheet" 
  />
</head>
<body class="font-sans text-secondary bg-surface antialiased selection:bg-primary selection:text-white overflow-x-hidden">
  <slot />

  <!-- Client-side Scripts -->
  <script>
    // Navbar Scroll Styling
    const navbar = document.getElementById('navbar');
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav-link');
    
    let isScrolling = false;

    window.addEventListener('scroll', () => {
      if (!isScrolling) {
        window.requestAnimationFrame(() => {
          let current = '';
          const scrollY = window.pageYOffset;

          if (scrollY > 10) {
            navbar?.classList.add('nav-scrolled');
            navbar?.classList.remove('glass-nav');
            navbar?.classList.remove('py-4');
            navbar?.classList.add('py-3');
          } else {
            navbar?.classList.remove('nav-scrolled');
            navbar?.classList.add('glass-nav');
            navbar?.classList.remove('py-3');
            navbar?.classList.add('py-4');
          }

          sections.forEach((section) => {
            const sectionHeight = (section as HTMLElement).offsetHeight;
            const sectionTop = (section as HTMLElement).offsetTop - 150;
            if (scrollY > sectionTop && scrollY <= sectionTop + sectionHeight) {
              current = section.getAttribute('id') || '';
            }
          });

          navLinks.forEach((link) => {
            link.classList.remove('active');
            if (link.getAttribute('href')?.includes(current) && current !== '') {
              link.classList.add('active');
            }
          });

          isScrolling = false;
        });
        isScrolling = true;
      }
    }, { passive: true });

    // Mobile Menu
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const openIcon = mobileBtn?.querySelector('.open-icon');
    const closeIcon = mobileBtn?.querySelector('.close-icon');

    mobileBtn?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.toggle('open');
      if (isOpen) {
        openIcon?.classList.add('hidden');
        closeIcon?.classList.remove('hidden');
      } else {
        openIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
      }
    });

    document.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu?.classList.remove('open');
        openIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
      });
    });

    // Accordion FAQ
    document.querySelectorAll('.accordion-button').forEach(button => {
      button.addEventListener('click', () => {
        const isExpanded = button.getAttribute('aria-expanded') === 'true';
        const content = button.nextElementSibling;
        
        document.querySelectorAll('.accordion-button').forEach(otherBtn => {
          if (otherBtn !== button) {
            otherBtn.setAttribute('aria-expanded', 'false');
            otherBtn.nextElementSibling?.classList.remove('active');
            (otherBtn.nextElementSibling as HTMLElement).style.paddingTop = '0';
          }
        });

        button.setAttribute('aria-expanded', !isExpanded ? 'true' : 'false');
        if (!isExpanded) {
          content?.classList.add('active');
          (content as HTMLElement).style.paddingTop = '1rem';
        } else {
          content?.classList.remove('active');
          (content as HTMLElement).style.paddingTop = '0';
        }
      });
    });

    // Intersection Observer for Animation Effects
    const observerOptions = {
      root: null,
      rootMargin: '150px',
      threshold: 0
    };

    const observer = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          obs.unobserve(entry.target);
        }
      });
    }, observerOptions);

    document.querySelectorAll('.animate-on-scroll').forEach(el => {
      observer.observe(el);
    });

    // Mark body as ready — only NOW start hiding unobserved elements
    document.body.classList.add('js-observer-ready');
  </script>
</body>
</html>
