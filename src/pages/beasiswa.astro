---
import Layout from '../layouts/Layout.astro';
import Ornament from '../components/Ornament.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import { Award, BookOpen, GraduationCap, ClipboardList, CheckCircle, ArrowRight, ShieldAlert, Cpu } from '@lucide/astro';

const programs = [
  {
    icon: Laptop => Cpu, // We can import Cpu or Laptop
    title: 'D3 Teknik Informatika',
    desc: 'Fokus pada pengembangan software, pemrograman web/mobile, basis data, jaringan, dan kecakapan komputasi awan (cloud computing). Program paling diminati untuk karier tech.',
  },
  {
    icon: Laptop => Cpu,
    title: 'D3 Teknik Mekatronika',
    desc: 'Integrasi antara ilmu teknik mesin, elektronika, dan kontrol komputer. Mempelajari sistem otomatisasi, robotika, dan internet of things (IoT) untuk manufaktur cerdas.',
  },
  {
    icon: Laptop => Cpu,
    title: 'D3 Teknik Telekomunikasi',
    desc: 'Mempelajari sistem komunikasi nirkabel, jaringan fiber optik, transmisi sinyal data, dan pemeliharaan infrastruktur jaringan seluler/satelit modern.',
  },
];

const requirements = [
  { title: 'Lulusan SMA/SMK/MA/Sederajat', desc: 'Terbuka untuk lulusan tahun 2024 atau 2025 dari seluruh sekolah formal maupun pondok pesantren.' },
  { title: 'Berasal dari Keluarga Prasejahtera', desc: 'Memiliki surat keterangan tidak mampu (SKTM) dari kelurahan setempat untuk memvalidasi beasiswa tepat sasaran.' },
  { title: 'Kesiapan Tinggal di Asrama', desc: 'Bersedia mematuhi tata tertib asrama Tholabie CIBS, berkomitmen mengikuti kegiatan ibadah, tahsin, diniyah, dan pelatihan digital.' },
  { title: 'Potensi Akademik & Minat Teknologi', desc: 'Memiliki komitmen belajar tinggi, minat besar di bidang digital marketing/teknologi, dan bersedia menyelesaikan studi D3.' },
];

const steps = [
  {
    num: '1',
    title: 'Registrasi WhatsApp',
    desc: 'Hubungi admin via WhatsApp untuk mendaftarkan nama, asal sekolah, dan minat program studi.',
  },
  {
    num: '2',
    title: 'Seleksi Berkas & Rapor',
    desc: 'Mengirimkan dokumen berupa scan rapor semester 1-5, kartu identitas, kartu keluarga, dan SKTM.',
  },
  {
    num: '3',
    title: 'Wawancara Daring/Luring',
    desc: 'Penilaian komitmen santri dan wali murid secara mendalam mengenai kesiapan asrama, akhlak, dan tekad studi.',
  },
  {
    num: '4',
    title: 'Daftar Ulang & Pendaftaran Politeknik',
    desc: 'Proses pengumuman penerimaan resmi, penandatanganan akad beasiswa, dan registrasi pendaftaran SNMPN/Politeknik.',
  },
];
---

<Layout title="Program Beasiswa Politeknik Malang - Pondok Pesantren THOLABIE CIBS" description="Informasi lengkap beasiswa penuh D3 Politeknik Kota Malang di Pesantren THOLABIE CIBS. Bebas biaya kuliah (UKT) 100%, asrama gratis, dan syarat pendaftaran.">
  <!-- Page Header -->
  <section class="relative pt-32 pb-16 overflow-hidden bg-primary text-white text-center">
    <div class="absolute inset-0 bg-islamic-pattern opacity-15"></div>
    <div class="absolute bottom-0 left-0 w-full h-1/2 bg-gradient-to-t from-black/25 to-transparent -z-10"></div>
    <div class="max-w-4xl mx-auto px-4 relative z-10 flex flex-col items-center">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="inline-flex items-center gap-2 text-xs font-semibold text-white/70 mb-4 bg-white/5 backdrop-blur-sm px-3.5 py-1.5 rounded-full border border-white/10 shadow-sm">
        <a href="/" class="hover:text-accent transition-colors">Beranda</a>
        <span class="text-accent-light/50 font-bold">&bull;</span>
        <span class="text-accent-light">Program Beasiswa</span>
      </nav>

      <span class="text-accent uppercase tracking-widest text-xs font-bold mb-3 block">Kesempatan Kuliah 100% Gratis</span>
      <h1 class="text-3xl md:text-4xl font-serif font-bold mb-4">Beasiswa D3 Politeknik Kota Malang</h1>
      <Ornament type="divider" class="mb-4" />
      <p class="text-white/80 max-w-2xl mx-auto text-sm md:text-base">Membuka jalan bagi pemuda Muslim berprestasi dari latar belakang ekonomi terbatas untuk menguasai masa depan cerah.</p>
    </div>
  </section>

  <!-- Detailed Benefit Section -->
  <section class="py-16 md:py-24 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 bg-islamic-pattern opacity-10 -z-10"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center mb-16">
        <div class="animate-on-scroll">
          <span class="text-primary uppercase tracking-widest text-xs font-bold mb-4 block">Cakupan Beasiswa</span>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-secondary mb-6">Fasilitas Pembiayaan Penuh Selama 3 Tahun</h2>
          <div class="space-y-6 text-gray-600 text-sm md:text-base leading-relaxed">
            <p>
              Beasiswa THOLABIE CIBS dirancang secara khusus untuk menghilangkan seluruh beban pembiayaan pendidikan agar santri dapat fokus 100% pada pencapaian akademis dan pengembangan keahlian digital.
            </p>
            <ul class="space-y-4">
              <li class="flex items-start gap-4 p-4 bg-white rounded-2xl border border-accent/15 shadow-premium">
                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0 border border-primary/20">
                  <CheckCircle class="w-5 h-5 text-primary" />
                </div>
                <div>
                  <h4 class="font-bold text-secondary text-sm md:text-base mb-1">100% Bebas Uang Kuliah Tunggal (UKT)</h4>
                  <p class="text-xs md:text-sm text-gray-500 leading-relaxed">Seluruh biaya semester di Politeknik Kota Malang ditanggung penuh dari awal hingga kelulusan (semester 1 sampai 6).</p>
                </div>
              </li>
              <li class="flex items-start gap-4 p-4 bg-white rounded-2xl border border-accent/15 shadow-premium">
                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0 border border-primary/20">
                  <CheckCircle class="w-5 h-5 text-primary" />
                </div>
                <div>
                  <h4 class="font-bold text-secondary text-sm md:text-base mb-1">Fasilitas Asrama Islami Gratis</h4>
                  <p class="text-xs md:text-sm text-gray-500 leading-relaxed">Menyediakan tempat tinggal yang bersih, aman, dan kondusif tanpa dipungut biaya sewa sepeser pun.</p>
                </div>
              </li>
              <li class="flex items-start gap-4 p-4 bg-white rounded-2xl border border-accent/15 shadow-premium">
                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0 border border-primary/20">
                  <CheckCircle class="w-5 h-5 text-primary" />
                </div>
                <div>
                  <h4 class="font-bold text-secondary text-sm md:text-base mb-1">Bahan Ajar & Modul Inkubasi</h4>
                  <p class="text-xs md:text-sm text-gray-500 leading-relaxed">Akses penuh ke materi kelas pemasaran digital, AI produktivitas, lisensi tools penunjang, dan pendampingan mentor gratis.</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
        
        <div class="animate-on-scroll delay-100 bg-white p-8 rounded-3xl border border-accent/20 shadow-premium relative overflow-hidden">
          <div class="absolute inset-0 bg-islamic-pattern opacity-5 -z-10"></div>
          <div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center text-accent-dark border border-accent/30 mb-6">
            <Award class="w-6 h-6" />
          </div>
          <h3 class="text-lg font-bold text-secondary mb-3">Ketentuan Ikatan Kerja</h3>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">
            Program beasiswa ini tidak menuntut ikatan dinas wajib kerja yang mengekang santri setelah lulus. Setelah lulus dari Politeknik, alumni dibebaskan untuk meniti karier di korporasi nasional, menjadi freelancer global, maupun merintis usaha (startup) sendiri dengan pendampingan inkubator bisnis Tholabie.
          </p>
          <div class="flex items-start gap-2 p-3 bg-secondary/5 rounded-xl border border-secondary/10">
            <ShieldAlert class="w-4 h-4 text-primary shrink-0 mt-0.5" />
            <p class="text-xs text-gray-500 leading-normal">Santri hanya diwajibkan untuk berakhlaqul karimah dan menjaga nama baik almamater pesantren selama masa studi.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pilihan Program Studi -->
  <section class="py-16 md:py-24 bg-surface-alt border-y border-accent/20 relative overflow-hidden">
    <div class="absolute inset-0 bg-islamic-pattern opacity-25 -z-10"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16 animate-on-scroll">
        <span class="text-primary uppercase tracking-widest text-xs font-bold mb-4 block">Formal Education</span>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-secondary mb-4">Pilihan Program Studi D3</h2>
        <Ornament type="divider" class="mb-6" />
        <p class="text-gray-600">Santri dapat memilih salah satu program studi D3 di Politeknik Kota Malang berikut sesuai minat dan bakat mereka:</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {programs.map((prog, idx) => {
          return (
            <div class="animate-on-scroll bg-white p-8 rounded-2xl shadow-premium border border-accent/10 hover:border-accent/30 hover:-translate-y-1 transition-all duration-300 group flex flex-col justify-between">
              <div>
                <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-6 text-primary border border-primary/20 group-hover:scale-105 transition-transform">
                  <Cpu class="w-6 h-6 text-accent" />
                </div>
                <h3 class="text-lg font-bold text-secondary mb-3">{prog.title}</h3>
                <p class="text-xs text-gray-500 leading-relaxed mb-6">{prog.desc}</p>
              </div>
              <div class="border-t border-gray-100 pt-4 flex justify-between items-center text-xs text-primary font-bold">
                <span>Mitra: Politeknik Kota Malang</span>
                <GraduationCap class="w-4 h-4 text-accent" />
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Persyaratan Pendaftaran -->
  <section class="py-16 md:py-24 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 bg-islamic-pattern opacity-30 -z-10"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16 animate-on-scroll">
        <span class="text-primary uppercase tracking-widest text-xs font-bold mb-4 block">Siapa Saja yang Berhak?</span>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-secondary mb-4">Syarat & Kriteria Penerimaan</h2>
        <Ornament type="divider" class="mb-6" />
        <p class="text-gray-600">Kriteria penerimaan beasiswa untuk menjaga integritas keadilan bantuan pendidikan:</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {requirements.map((req, idx) => (
          <div class="animate-on-scroll bg-white p-6 rounded-2xl border border-accent/15 shadow-sm hover:border-accent/35 hover:-translate-y-0.5 transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-full bg-accent/20 text-accent-dark flex items-center justify-center font-bold text-xs shrink-0 border border-accent/30 mt-0.5">
                {idx + 1}
              </div>
              <div>
                <h4 class="font-bold text-secondary text-sm md:text-base mb-1.5">{req.title}</h4>
                <p class="text-xs text-gray-500 leading-relaxed">{req.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Jalur Pendaftaran (Timeline) -->
  <section class="py-16 md:py-24 bg-surface-alt border-t border-accent/20 relative overflow-hidden">
    <div class="absolute inset-0 bg-islamic-pattern opacity-10 -z-10"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16 animate-on-scroll">
        <span class="text-primary uppercase tracking-widest text-xs font-bold mb-4 block">Alur Penerimaan</span>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-secondary mb-4">Tahapan Seleksi Beasiswa</h2>
        <Ornament type="divider" class="mb-6" />
        <p class="text-gray-600">Berikut adalah tahapan transparan pendaftaran beasiswa Tholabie CIBS 2026:</p>
      </div>

      <div class="relative max-w-5xl mx-auto">
        <!-- Horizontal Timeline Bar (Desktop) -->
        <div class="hidden md:block absolute top-1/2 left-0 w-full h-0.5 bg-gradient-to-r from-primary/30 via-accent/50 to-primary/30 -translate-y-1/2"></div>
        
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 relative z-10">
          {steps.map((step) => (
            <div class="animate-on-scroll bg-white p-6 rounded-2xl border border-accent/15 relative text-center shadow-premium hover:border-accent/35 transition-all duration-300">
              <div class="w-10 h-10 rounded-full bg-primary text-white font-bold flex items-center justify-center absolute -top-5 left-1/2 -translate-x-1/2 border-2 border-accent shadow-md">
                {step.num}
              </div>
              <h4 class="font-bold text-secondary mt-5 mb-2 text-sm">{step.title}</h4>
              <p class="text-xs text-gray-500 leading-relaxed">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <FinalCTA />
</Layout>
