---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { Calendar, Clock } from '@lucide/astro';

const articles = [
  { slug: 'literasi-ai-santri-era-digital', title: 'Pentingnya Literasi AI bagi Santri Abad 21', category: 'Teknologi', date: '2026-06-25', readTime: '7 min read', excerpt: 'Di era kecerdasan buatan, santri tidak boleh gagap teknologi. Ketahui bagaimana Tholabie CIBS memadukan pengajaran AI dengan pembiasaan adab.', featured: true },
  { slug: 'panduan-beasiswa-politeknik-sktm', title: 'Jalur Beasiswa Penuh D3 Politeknik Malang: Panduan SKTM', category: 'Pendidikan', date: '2026-06-20', readTime: '5 min read', excerpt: 'Persiapkan berkas seleksi beasiswa Tholabie sedini mungkin. Panduan lengkap raport dan SKTM.' },
  { slug: 'adab-menuntut-ilmu-era-digital', title: 'Menjaga Adab Menuntut Ilmu di Era Digital', category: 'Keislaman', date: '2026-06-15', readTime: '6 min read', excerpt: 'Adab mendahului ilmu. Menelaah bagaimana santri melatih disiplin spiritual di era internet.' },
  { slug: 'peluang-bisnis-dropship-santri', title: 'Peluang Bisnis Dropship untuk Kemandirian Santri', category: 'Bisnis', date: '2026-06-10', readTime: '5 min read', excerpt: 'Bagaimana santri diajarkan merintis bisnis e-commerce tanpa modal besar di asrama.' },
];

const featuredArticle = articles.find(a => a.featured);
const latestArticles = articles.filter(a => !a.featured);
---
<Layout title="Blog & Artikel — Tholabie CIBS">
  <Navbar />
  
  <main class="flex-grow">
    <section class="relative overflow-hidden bg-gradient-to-b from-surface to-white py-16 border-b border-gray-100">
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#e6dfd3_1px,transparent_1px),linear-gradient(to_bottom,#e6dfd3_1px,transparent_1px)] bg-[size:12rem_12rem] opacity-5"></div>
      <div class="mx-auto max-w-7xl px-6 lg:px-8 relative z-10 text-center">
        <h1 class="font-serif text-4xl sm:text-5xl font-bold tracking-tight text-secondary mb-4">Tholabie Knowledge Base</h1>
        <p class="mx-auto max-w-2xl text-sm sm:text-base text-slate-600 leading-relaxed">
          Kumpulan artikel, riset diniyah, literasi AI, dan tips bisnis digital dari santri, ustadz, dan praktisi industri.
        </p>
      </div>
    </section>

    <section class="py-20 bg-white">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        {featuredArticle && (
          <div class="mb-16">
            <h2 class="text-xs font-bold text-accent uppercase tracking-widest mb-6">Artikel Pilihan Utama</h2>
            <a href={`/blog/${featuredArticle.slug}`} class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center border border-gray-100 rounded-2xl bg-surface-alt/50 p-6 sm:p-8 hover:border-primary/20 transition-all block group">
              <div class="lg:col-span-5 aspect-[3/2] w-full rounded-xl bg-primary/10 border border-gray-200 flex items-center justify-center relative overflow-hidden">
                <span class="absolute top-4 left-4 bg-primary text-white text-xs font-bold px-2.5 py-0.5 rounded uppercase tracking-widest">{featuredArticle.category}</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary/20"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg>
              </div>
              <div class="lg:col-span-7 space-y-4">
                <div class="flex items-center gap-4 text-xs text-slate-400 font-semibold uppercase tracking-wider">
                  <span class="flex items-center gap-1.5"><Calendar class="w-3.5 h-3.5" />{featuredArticle.date}</span>
                  <span class="flex items-center gap-1.5"><Clock class="w-3.5 h-3.5" />{featuredArticle.readTime}</span>
                </div>
                <h3 class="font-serif text-2xl sm:text-3xl font-bold text-secondary group-hover:text-primary transition-colors leading-tight">{featuredArticle.title}</h3>
                <p class="text-slate-500 text-sm leading-relaxed">{featuredArticle.excerpt}</p>
                <span class="inline-flex items-center gap-2 text-sm font-bold text-accent pt-2">Baca Selengkapnya →</span>
              </div>
            </a>
          </div>
        )}

        <div>
          <h2 class="text-xs font-bold text-accent uppercase tracking-widest mb-8">Artikel Terbaru</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {latestArticles.map(a => (
              <a href={`/blog/${a.slug}`} class="border border-gray-100 bg-white rounded-2xl p-6 flex flex-col justify-between hover:border-primary/20 hover:shadow-md transition-all group">
                <div>
                  <div class="aspect-[3/2] w-full rounded-xl bg-primary/5 border border-gray-200 flex items-center justify-center mb-6 relative overflow-hidden">
                    <span class="absolute top-3 left-3 bg-primary text-white text-xs font-bold px-2 py-0.5 rounded uppercase tracking-widest">{a.category}</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary/15"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg>
                  </div>
                  <div class="flex items-center gap-3 text-xs text-slate-400 font-semibold uppercase tracking-wider mb-3">
                    <span class="flex items-center gap-1"><Calendar class="w-3 h-3" />{a.date}</span>
                    <span class="flex items-center gap-1"><Clock class="w-3 h-3" />{a.readTime}</span>
                  </div>
                  <h3 class="font-bold text-secondary text-base mb-2 group-hover:text-primary transition-colors line-clamp-2">{a.title}</h3>
                  <p class="text-xs text-slate-500 leading-relaxed mb-6 line-clamp-3">{a.excerpt}</p>
                </div>
                <span class="inline-flex items-center gap-2 text-xs font-bold text-accent">Baca Selengkapnya →</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
