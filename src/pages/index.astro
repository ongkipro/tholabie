---
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import InstitutionSnapshot from '../components/InstitutionSnapshot.astro';
import ProblemSolution from '../components/ProblemSolution.astro';
import About from '../components/About.astro';
import EducationEcosystem from '../components/EducationEcosystem.astro';
import Scholarship from '../components/Scholarship.astro';
import BoardingLife from '../components/BoardingLife.astro';
import DigitalSkills from '../components/DigitalSkills.astro';
import Transformation from '../components/Transformation.astro';
import WhyTrust from '../components/WhyTrust.astro';
import AdmissionProcess from '../components/AdmissionProcess.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
import StickyCTA from '../components/StickyCTA.astro';

import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#064E3B" />
  <title>Pondok Pesantren THOLABIE CIBS | Beasiswa Politeknik Kota Malang</title>
  <meta name="description" content="Pondok Pesantren THOLABIE Classic International Boarding School. Pendidikan asrama Islami terpadu dengan beasiswa D3 Politeknik Kota Malang dan inkubasi keahlian digital. Menjembatani Iman, Ilmu, dan Karier Masa Depan." />
  
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Amiri+Quran&display=swap" rel="stylesheet">
</head>
<body class="font-sans text-secondary bg-surface antialiased selection:bg-primary selection:text-white overflow-x-hidden">
  <Navbar />
  <main>
    <Hero />
    <InstitutionSnapshot />
    <ProblemSolution />
    <About />
    <EducationEcosystem />
    <Scholarship />
    <BoardingLife />
    <DigitalSkills />
    <Transformation />
    <WhyTrust />
    <AdmissionProcess />
    <Testimonials />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
  <StickyCTA />

  <!-- Client-side Scripts -->
  <script>
    // Navbar Scroll Styling
    const navbar = document.getElementById('navbar');
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav-link');
    
    let isScrolling = false;

    window.addEventListener('scroll', () => {
      if (!isScrolling) {
        window.requestAnimationFrame(() => {
          let current = '';
          const scrollY = window.pageYOffset;

          if (scrollY > 10) {
            navbar?.classList.add('nav-scrolled');
            navbar?.classList.remove('glass-nav');
            navbar?.classList.remove('py-4');
            navbar?.classList.add('py-3');
          } else {
            navbar?.classList.remove('nav-scrolled');
            navbar?.classList.add('glass-nav');
            navbar?.classList.remove('py-3');
            navbar?.classList.add('py-4');
          }

          sections.forEach((section) => {
            const sectionHeight = (section as HTMLElement).offsetHeight;
            const sectionTop = (section as HTMLElement).offsetTop - 150;
            if (scrollY > sectionTop && scrollY <= sectionTop + sectionHeight) {
              current = section.getAttribute('id') || '';
            }
          });

          navLinks.forEach((link) => {
            link.classList.remove('active');
            if (link.getAttribute('href')?.includes(current) && current !== '') {
              link.classList.add('active');
            }
          });

          isScrolling = false;
        });
        isScrolling = true;
      }
    }, { passive: true });

    // Mobile Menu Button Action
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const openIcon = mobileBtn?.querySelector('.open-icon');
    const closeIcon = mobileBtn?.querySelector('.close-icon');

    mobileBtn?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.toggle('open');
      if (isOpen) {
        mobileMenu?.classList.add('open');
        openIcon?.classList.add('hidden');
        closeIcon?.classList.remove('hidden');
      } else {
        mobileMenu?.classList.remove('open');
        openIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
      }
    });

    // Close Mobile Menu on Link Click
    document.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu?.classList.remove('open');
        openIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
      });
    });

    // Accordion FAQ Toggles
    document.querySelectorAll('.accordion-button').forEach(button => {
      button.addEventListener('click', () => {
        const isExpanded = button.getAttribute('aria-expanded') === 'true';
        const content = button.nextElementSibling;
        
        document.querySelectorAll('.accordion-button').forEach(otherBtn => {
          if (otherBtn !== button) {
            otherBtn.setAttribute('aria-expanded', 'false');
            otherBtn.nextElementSibling?.classList.remove('active');
            (otherBtn.nextElementSibling as HTMLElement).style.paddingTop = '0';
          }
        });

        button.setAttribute('aria-expanded', !isExpanded ? 'true' : 'false');
        if (!isExpanded) {
          content?.classList.add('active');
          (content as HTMLElement).style.paddingTop = '1rem';
        } else {
          content?.classList.remove('active');
          (content as HTMLElement).style.paddingTop = '0';
        }
      });
    });

    // Intersection Observer for Animation Effects
    document.addEventListener("DOMContentLoaded", () => {
      const observerOptions = {
        root: null,
        rootMargin: '50px',
        threshold: 0.1
      };

      const observer = new IntersectionObserver((entries, obs) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            obs.unobserve(entry.target);
          }
        });
      }, observerOptions);

      document.querySelectorAll('.animate-on-scroll').forEach(el => {
        observer.observe(el);
      });
    });
  </script>
</body>
</html>
