---
import Layout from '../layouts/Layout.astro';
import Ornament from '../components/Ornament.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import { Sunrise, Building2, Laptop, Moon, Coffee, Home, HelpCircle, Check, MapPin } from '@lucide/astro';

const schedule = [
  {
    time: '03.00 - 05.00',
    title: 'Qiyamul Lail & Subuh',
    desc: 'Bangun pagi, shalat tahajud berjamaah, tadabbur Al-Qur\'an, shalat subuh berjamaah, dan dzikir pagi.',
    icon: Sunrise,
    bgColor: 'bg-primary/10',
    textColor: 'text-primary',
  },
  {
    time: '07.00 - 15.00',
    title: 'Perkuliahan Kampus',
    desc: 'Sarapan pagi, berangkat ke kampus Politeknik Kota Malang untuk menempuh perkuliahan formal D3 sesuai program studi.',
    icon: Building2,
    bgColor: 'bg-secondary/10',
    textColor: 'text-secondary',
  },
  {
    time: '15.30 - 17.30',
    title: 'Inkubasi Keahlian Digital',
    desc: 'Pelatihan praktis kelas digital marketing, pemanfaatan AI untuk produktivitas, pembuatan portofolio toko online, & kelas bahasa.',
    icon: Laptop,
    bgColor: 'bg-accent/15',
    textColor: 'text-accent-dark',
  },
  {
    time: '18.00 - 21.30',
    title: 'Diniyah & Istirahat',
    desc: 'Shalat maghrib & isya berjamaah, kajian diniyah (adab, aqidah, tafsir), makan malam bersama, dan jam belajar mandiri.',
    icon: Moon,
    bgColor: 'bg-primary-dark/10',
    textColor: 'text-primary-dark',
  },
];

const facilities = [
  { name: 'Kamar Tidur Bersih & Rapi', desc: 'Asrama bertipe kamar bersama yang terstruktur rapi untuk melatih kedisiplinan dan kebersamaan.' },
  { name: 'Mushola & Aula Belajar', desc: 'Fasilitas ibadah berjamaah serta ruang serbaguna yang nyaman untuk kelas sore, mentoring, dan diskusi kelompok.' },
  { name: 'Infrastruktur Internet Cepat', desc: 'Akses Wi-Fi serat optik berkecepatan tinggi gratis untuk memfasilitasi santri belajar pemrograman, AI, dan bisnis digital.' },
  { name: 'Perpustakaan Buku Agama & IT', desc: 'Koleksi lengkap buku-buku tsaqafah Islam, adab, kitab kuning, serta buku penunjang IT, desain, dan bisnis digital.' },
];
---

<Layout title="Kehidupan Asrama Islami | Pondok Pesantren THOLABIE CIBS" description="Mengintip kehidupan asrama Islami yang terstruktur di THOLABIE CIBS Malang. Jadwal harian santri dari Qiyamul Lail hingga inkubasi teknologi digital.">
  <!-- Page Header -->
  <section class="relative pt-32 pb-16 overflow-hidden bg-primary text-white text-center">
    <div class="absolute inset-0 bg-islamic-pattern opacity-15"></div>
    <div class="absolute bottom-0 left-0 w-full h-1/2 bg-gradient-to-t from-black/25 to-transparent -z-10"></div>
    <div class="max-w-4xl mx-auto px-4 relative z-10 flex flex-col items-center">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="inline-flex items-center gap-2 text-xs font-semibold text-white/70 mb-4 bg-white/5 backdrop-blur-sm px-3.5 py-1.5 rounded-full border border-white/10 shadow-sm">
        <a href="/" class="hover:text-accent transition-colors">Beranda</a>
        <span class="text-accent-light/50 font-bold">&bull;</span>
        <span class="text-accent-light">Kehidupan Asrama</span>
      </nav>

      <span class="text-accent uppercase tracking-widest text-xs font-bold mb-3 block">Biah Shalihah (Lingkungan Baik)</span>
      <h1 class="text-3xl md:text-4xl font-serif font-bold mb-4">Kehidupan Asrama Terstruktur</h1>
      <Ornament type="divider" class="mb-4" />
      <p class="text-white/80 max-w-2xl mx-auto text-sm md:text-base">Membangun akhlak mulia dan kedisiplinan tinggi melalui bimbingan spiritual harian yang terarah.</p>
    </div>
  </section>

  <!-- Daily Rhythm Timeline -->
  <section class="py-16 md:py-24 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 bg-islamic-pattern opacity-10 -z-10"></div>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16 animate-on-scroll">
        <span class="text-primary uppercase tracking-widest text-xs font-bold mb-4 block">Rutinitas Harian</span>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-secondary mb-4">Agenda Harian Santri</h2>
        <Ornament type="divider" class="mb-6" />
        <p class="text-gray-600">Rutinitas yang didesain secara seimbang antara ibadah harian, kuliah akademik, dan inkubasi digital:</p>
      </div>

      <div class="space-y-8 relative max-w-3xl mx-auto">
        <!-- Vertical Line (Desktop) -->
        <div class="hidden md:block absolute left-[27px] top-4 bottom-4 w-0.5 bg-gradient-to-b from-primary via-accent to-secondary opacity-30"></div>
        
        {schedule.map((item, idx) => {
          const Icon = item.icon;
          return (
            <div class="flex flex-col md:flex-row gap-6 relative z-10 animate-on-scroll">
              <!-- Bullet Icon -->
              <div class={`w-14 h-14 rounded-full ${item.bgColor} ${item.textColor} flex items-center justify-center shrink-0 border border-accent/25 shadow-md`}>
                <Icon class="w-6 h-6" />
              </div>
              <!-- Content Card -->
              <div class="flex-1 bg-white p-6 rounded-2xl border border-accent/15 shadow-sm hover:border-accent/35 hover:-translate-y-0.5 transition-all duration-300">
                <span class="text-xs font-bold text-accent-dark tracking-wider uppercase bg-accent/10 px-2.5 py-1 rounded-full mb-3 inline-block">
                  {item.time}
                </span>
                <h4 class="font-bold text-secondary text-base md:text-lg mb-2">{item.title}</h4>
                <p class="text-xs md:text-sm text-gray-500 leading-relaxed">{item.desc}</p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Facilities Grid -->
  <section class="py-16 md:py-24 bg-surface-alt border-y border-accent/20 relative overflow-hidden">
    <div class="absolute inset-0 bg-islamic-pattern opacity-25 -z-10"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="animate-on-scroll">
          <span class="text-primary uppercase tracking-widest text-xs font-bold mb-4 block">Fasilitas Nyaman</span>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-secondary mb-6">Mendukung Pembinaan Karakter & Akademik</h2>
          <p class="text-gray-600 text-sm md:text-base leading-relaxed mb-8">
            Asrama Tholabie CIBS didesain untuk menjadi rumah kedua yang nyaman, aman, dan sarat dengan atmosfer religius yang produktif. Kami menyediakan fasilitas modern yang menunjang kebutuhan fisik, spiritual, dan teknologi santri.
          </p>
          <div class="grid sm:grid-cols-2 gap-4">
            {facilities.map((fac) => (
              <div class="p-4 bg-white rounded-xl border border-accent/15 shadow-sm">
                <div class="flex items-center gap-2 mb-2 text-primary font-bold text-sm">
                  <Check class="w-4 h-4 text-accent shrink-0" />
                  <span>{fac.name}</span>
                </div>
                <p class="text-xs text-gray-500 leading-normal">{fac.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="animate-on-scroll delay-100 grid grid-cols-2 gap-4">
          <div class="aspect-square bg-gray-200 rounded-2xl overflow-hidden shadow-md border border-accent/25">
            <img src="/img/pondok-pesantren-tholabie-malang.webp" alt="Asrama nyaman Tholabie" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="aspect-square bg-gray-200 rounded-2xl overflow-hidden shadow-md border border-accent/25">
            <img src="/img/pondok-tholabie-malang.webp" alt="Pembelajaran komputer Tholabie" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="aspect-square bg-gray-200 rounded-2xl overflow-hidden shadow-md border border-accent/25 col-span-2">
            <img src="/img/pesantren-tholabie-malang.webp" alt="Kebersamaan santri Tholabie" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Location Map info -->
  <section class="py-16 md:py-24 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 bg-islamic-pattern opacity-30 -z-10"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <span class="text-primary uppercase tracking-widest text-xs font-bold mb-4 block">Lokasi Fisik</span>
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-secondary mb-6">Lingkungan Asrama di Kota Malang</h2>
      <div class="max-w-2xl mx-auto bg-white p-6 rounded-2xl border border-accent/25 shadow-premium flex flex-col md:flex-row items-center gap-6 text-left">
        <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0 border border-primary/20">
          <MapPin class="w-6 h-6" />
        </div>
        <div>
          <h4 class="font-bold text-secondary text-sm md:text-base mb-1">Alamat Asrama Resmi:</h4>
          <p class="text-xs text-gray-500 leading-relaxed mb-2">
            Jalan Kyai Malik Dalam Jl. Dukuh Baran, RT.01/RW.07, Buring, Kec. Kedungkandang, Kota Malang, Jawa Timur 65136
          </p>
          <p class="text-xs text-primary font-semibold leading-relaxed mb-4">
            * Dekat dengan akses transportasi dan berjarak strategis dengan Politeknik Kota Malang.
          </p>
          <a
            href="https://maps.app.goo.gl/XqQ8ekM3c3GaGVTi6"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 px-4 py-2 bg-accent hover:bg-accent-light text-primary-dark font-bold text-xs rounded-full transition-all duration-300 shadow-sm border border-accent/25"
          >
            Buka Rute Google Maps &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <FinalCTA />
</Layout>
