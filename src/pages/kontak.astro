---
import Layout from '../layouts/Layout.astro';
import Ornament from '../components/Ornament.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import FAQ from '../components/sections/FAQ.astro';
import { Mail, Phone, MapPin, MessageCircle, Clock, ExternalLink } from '@lucide/astro';
---

<Layout title="Hubungi Kami & FAQ | Pondok Pesantren THOLABIE CIBS" description="Pusat informasi pendaftaran Pesantren THOLABIE CIBS. Hubungi admin WhatsApp resmi, lihat alamat lokasi, peta Google Maps, dan tanya jawab (FAQ).">
  <!-- Page Header -->
  <section class="relative pt-32 pb-16 overflow-hidden bg-primary text-white text-center">
    <div class="absolute inset-0 bg-islamic-pattern opacity-15"></div>
    <div class="absolute bottom-0 left-0 w-full h-1/2 bg-gradient-to-t from-black/25 to-transparent -z-10"></div>
    <div class="max-w-4xl mx-auto px-4 relative z-10 flex flex-col items-center">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="inline-flex items-center gap-2 text-xs font-semibold text-white/70 mb-4 bg-white/5 backdrop-blur-sm px-3.5 py-1.5 rounded-full border border-white/10 shadow-sm">
        <a href="/" class="hover:text-accent transition-colors">Beranda</a>
        <span class="text-accent-light/50 font-bold">&bull;</span>
        <span class="text-accent-light">Hubungi Kami</span>
      </nav>

      <span class="text-accent uppercase tracking-widest text-xs font-bold mb-3 block">Pusat Informasi Terpadu</span>
      <h1 class="text-3xl md:text-4xl font-serif font-bold mb-4">Hubungi Kami & FAQ</h1>
      <Ornament type="divider" class="mb-4" />
      <p class="text-white/80 max-w-2xl mx-auto text-sm md:text-base">Butuh bantuan? Silakan hubungi kami melalui saluran komunikasi resmi di bawah ini.</p>
    </div>
  </section>

  <!-- Contact & Map Grid -->
  <section class="py-16 md:py-24 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 bg-islamic-pattern opacity-10 -z-10"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-8 items-stretch">
        
        <!-- Saluran Komunikasi (2/5 width) -->
        <div class="lg:col-span-2 space-y-6 flex flex-col justify-between animate-on-scroll">
          <div class="space-y-4">
            <span class="text-primary uppercase tracking-widest text-xs font-bold block">Saluran Komunikasi</span>
            <h2 class="text-3xl md:text-4xl font-serif font-bold text-secondary mb-4">Hubungi Admin Resmi</h2>
            <p class="text-gray-600 text-sm leading-relaxed mb-6">
              Tim Hubungan Masyarakat kami siap melayani pertanyaan seputar pendaftaran santri baru, kurikulum digital, dan syarat kelayakan beasiswa.
            </p>
          </div>

          <div class="space-y-4">
            <!-- WA Card -->
            <div class="bg-white p-5 rounded-2xl border border-accent/15 shadow-sm hover:border-accent/35 hover:-translate-y-0.5 transition-all duration-300">
              <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary border border-primary/20 shrink-0">
                  <MessageCircle class="w-6 h-6" />
                </div>
                <div>
                  <h4 class="font-bold text-secondary text-sm md:text-base">WhatsApp Pendaftaran</h4>
                  <p class="text-xs text-gray-400">Respon cepat (Fast Response)</p>
                </div>
              </div>
              <a
                href="https://wa.me/6285183003060"
                target="_blank"
                rel="noopener noreferrer"
                class="block w-full text-center px-4 py-3 bg-accent hover:bg-accent-light text-primary-dark font-bold text-xs rounded-full transition-all duration-300 shadow-sm"
              >
                Hubungi via WhatsApp
              </a>
            </div>

            <!-- Hotline & Email Card -->
            <div class="bg-white p-5 rounded-2xl border border-accent/15 shadow-sm space-y-4">
              <div class="flex items-start gap-3">
                <Phone class="w-5 h-5 text-accent shrink-0 mt-0.5" />
                <div>
                  <h5 class="font-bold text-secondary text-sm">Telepon Pendaftaran:</h5>
                  <p class="text-xs text-gray-500 mt-0.5 font-medium">+62 851 8300 3060</p>
                </div>
              </div>
              
              <div class="flex items-start gap-3">
                <Mail class="w-5 h-5 text-accent shrink-0 mt-0.5" />
                <div>
                  <h5 class="font-bold text-secondary text-sm">Email Korespondensi:</h5>
                  <p class="text-xs text-gray-500 mt-0.5 font-medium">info@tholabiecibs.sch.id</p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <Clock class="w-5 h-5 text-accent shrink-0 mt-0.5" />
                <div>
                  <h5 class="font-bold text-secondary text-sm">Jam Operasional Layanan:</h5>
                  <p class="text-xs text-gray-500 mt-0.5">Senin - Ahad, 08.00 - 17.00 WIB</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Peta & Alamat Fisik (3/5 width) -->
        <div class="lg:col-span-3 space-y-6 animate-on-scroll delay-100 flex flex-col justify-between">
          <div class="space-y-4">
            <span class="text-primary uppercase tracking-widest text-xs font-bold block">Lokasi Kampus & Asrama</span>
            <h2 class="text-3xl md:text-4xl font-serif font-bold text-secondary mb-4">Kunjungi Pesantren Kami</h2>
            
            <div class="bg-white p-4 rounded-2xl border border-accent/15 shadow-sm flex items-start gap-3">
              <MapPin class="w-5 h-5 text-accent shrink-0 mt-1" />
              <div class="text-xs md:text-sm text-gray-600 leading-relaxed">
                <strong class="text-secondary font-bold">Pondok Pesantren THOLABIE CIBS:</strong><br />
                Jalan Kyai Malik Dalam Jl. Dukuh Baran, RT.01/RW.07, Buring, Kec. Kedungkandang, Kota Malang, Jawa Timur 65136
              </div>
            </div>
          </div>

          <!-- Google Maps Embed Frame -->
          <div class="relative w-full overflow-hidden rounded-2xl border-2 border-accent/20 shadow-premium group">
            <iframe
              class="w-full h-80 md:h-[340px] rounded-2xl border-none"
              src="https://maps.google.com/maps?q=-8.0145011,112.6611340&t=&z=16&ie=UTF8&iwloc=&output=embed"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
            <a
              href="https://maps.app.goo.gl/XqQ8ekM3c3GaGVTi6"
              target="_blank"
              rel="noopener noreferrer"
              class="absolute bottom-3 right-3 inline-flex items-center gap-1.5 px-3 py-1.5 bg-secondary/90 hover:bg-secondary text-white text-xs font-bold rounded-lg border border-accent/30 shadow-md backdrop-blur-sm transition-colors"
            >
              Buka di Google Maps <ExternalLink class="w-3 h-3" />
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- FAQ Accordion Section -->
  <FAQ />

  <FinalCTA />
</Layout>
